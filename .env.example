GEMINI_API_KEY=tu_clave_de_gemini
GEMINI_MODEL=gemini-2.5-flash
DATABASE_URL=sqlite:///./app/data/radiografia_bot.db
JWT_SECRET_KEY=genera-con: python -c "import secrets; print(secrets.token_urlsafe(32))"
GOOGLE_CLIENT_ID=tu-client-id.apps.googleusercontent.com
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173
DEBUG=true
ENVIRONMENT=development

# ===== FIREBASE CONFIGURATION =====
FIREBASE_PROJECT_ID=tu-proyecto-firebase-id

# Variables del Frontend (Vite)
VITE_FIREBASE_API_KEY=tu-firebase-api-key
VITE_FIREBASE_AUTH_DOMAIN=tu-proyecto-id.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=tu-proyecto-firebase-id
VITE_FIREBASE_STORAGE_BUCKET=tu-proyecto-id.appspot.com
VITE_FIREBASE_MESSAGING_SENDER_ID=tu-sender-id
VITE_FIREBASE_APP_ID=tu-app-id
